  "roles": {
    "realm": [
      {
        "name": "VETERINER",
        "description": "Veteriner Hekim - Hayvan sağlık kayıtlarına tam erişim"
      },
      {
        "name": "SEKRETER", 
        "description": "Klinik Sekreteri - Randevu, fatura ve genel yönetim"
      },
      {
        "name": "TEKNISYEN",
        "description": "Veteriner Teknisyeni - Laboratuvar ve teknik işlemler"
      },
      {
        "name": "ADMIN",
        "description": "Sistem Yöneticisi - Tüm sistem fonksiyonlarına erişim"
      }
    ]
  },
  "groups": [
    {
      "name": "Veterinerler",
      "path": "/Veterinerler",
      "realmRoles": ["VETERINER"]
    },
    {
      "name": "Sekreterler", 
      "path": "/Sekreterler",
      "realmRoles": ["SEKRETER"]
    },
    {
      "name": "Teknisyenler",
      "path": "/Teknisyenler", 
      "realmRoles": ["TEKNISYEN"]
    },
    {
      "name": "Yöneticiler",
      "path": "/Yöneticiler",
      "realmRoles": ["ADMIN"]
    }
  ],
